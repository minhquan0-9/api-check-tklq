# Provider dùng cho lookup nickname:
#   - mock: trả về dữ liệu giả lập (mặc định, dùng cho dev/test)
#   - garena_shop: gọi endpoint shop chính thức của Garena (chỉ chạy được từ IP Việt Nam)
LIENQUAN_PROVIDER=mock

# Cấu hình cho garena_shop provider (chỉ dùng khi LIENQUAN_PROVIDER=garena_shop)
GARENA_SHOP_BASE_URL=https://shop.garena.vn
GARENA_SHOP_APP_ID=100067
GARENA_SHOP_TIMEOUT=10

# CORS — danh sách origin phân cách bằng dấu phẩy ("*" cho phép tất cả)
CORS_ORIGINS=*

# Cấu hình server
HOST=0.0.0.0
PORT=8000
